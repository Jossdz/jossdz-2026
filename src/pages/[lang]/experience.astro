---
import "@/styles/global.css";
import Layout from "@/layouts/Layout.astro";
import ExperienceList from "@/components/ExperienceList";
import { languages, type Lang } from "@/i18n/ui";
import { useTranslations } from "@/i18n/utils";

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);

const titles: Record<Lang, string> = {
  en: "Work Experience — Jose Carlos Correa",
  es: "Experiencia Laboral — Jose Carlos Correa",
};

const descriptions: Record<Lang, string> = {
  en: "Professional history of Jose Carlos Correa — Frontend Engineer at Team Liquid, Lead Instructor at Ironhack, and course creator at Platzi.",
  es: "Trayectoria profesional de Jose Carlos Correa — Ingeniero Frontend en Team Liquid, Instructor en Ironhack y creador de cursos en Platzi.",
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": `https://jossdz.com/${lang}/` },
    { "@type": "ListItem", "position": 2, "name": t("experience.title"), "item": `https://jossdz.com/${lang}/experience` },
  ],
};
---

<Layout lang={lang} title={titles[lang]} description={descriptions[lang]} currentPath="/experience">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />
  <section class="min-h-screen px-6 pt-20 pb-32 max-w-5xl mx-auto">
    <h1
      class="font-bold leading-none text-ghost-white"
      style="font-size: clamp(2rem, 15vw, 10rem)"
    >
      {t("experience.title")}
    </h1>
    <p class="text-pale-slate text-sm md:text-xl mt-4">
      {t("experience.subtitle")}
    </p>
    <ExperienceList lang={lang} client:visible />
  </section>
</Layout>
