---
import "@/styles/global.css";
import Layout from "@/layouts/Layout.astro";
import ExperienceList from "@/components/ExperienceList";
import { languages, type Lang } from "@/i18n/ui";
import { useTranslations } from "@/i18n/utils";

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);
---

<Layout lang={lang}>
  <section class="min-h-screen px-6 pt-20 pb-32 max-w-5xl mx-auto">
    <h1 class="text-9xl font-bold leading-none text-ghost-white">{t("experience.title")}</h1>
    <p class="text-pale-slate text-xl mt-1 mb-16">
      {t("experience.subtitle")}
    </p>
    <ExperienceList lang={lang} client:load />
  </section>
</Layout>
