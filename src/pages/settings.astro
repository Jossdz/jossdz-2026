---
import "@/styles/global.css";
import Layout from "@/layouts/Layout.astro";
---

<Layout>
  <section class="min-h-screen px-6 pt-20 pb-32 max-w-7xl mx-auto">
    <h1 class="text-9xl font-bold leading-none text-ghost-white">Config</h1>
    <p class="text-pale-slate text-xl mt-1 mb-16">
      Preferences and configuration options.
    </p>

    <div class="space-y-12">
      <!-- Language -->
      <div>
        <h2 class="text-ghost-white text-2xl font-semibold mb-4">Language</h2>
        <p class="text-pale-slate text-sm mb-6">
          Select your preferred language for the site interface.
        </p>
        <div class="flex gap-3">
          <button
            class="px-5 py-2.5 rounded-lg border border-ghost-white bg-ghost-white text-raisin-black text-sm font-medium"
            aria-pressed="true"
          >
            en-US
          </button>
          <button
            class="px-5 py-2.5 rounded-lg border border-pale-slate text-pale-slate text-sm font-medium hover:border-ghost-white hover:text-ghost-white transition-colors"
            aria-pressed="false"
          >
            es-MX
          </button>
        </div>
      </div>
    </div>
  </section>
</Layout>
