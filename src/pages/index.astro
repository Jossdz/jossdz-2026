---
import "@/styles/global.css";
import LineWaves from "@/components/LineWaves";
import Layout from "@/layouts/Layout.astro";
import SplitText from "@/components/SplitText";
import TiltedCard from "@/components/TiltedCard";
import CurvedLoop from "@/components/CurvedLoop";
---

<Layout>
  <div class="w-full relative h-screen bg-shadow-grey">
    <LineWaves
      client:load
      brightness={0.2}
      color1="#43627c"
      color2="#365571"
      color3="#2c4a63"
      colorCycleSpeed={1}
      edgeFadeWidth={0}
      enableMouseInteraction={false}
      innerLineCount={36}
      mouseInfluence={2}
      outerLineCount={19}
      rotation={-46}
      speed={0.2}
      warpIntensity={2.4}
    />
    <div
      class="w-full text-center absolute top-1/2 left-0 translate-y-[calc(-50%-50px)]"
    >
      <h1 class="text-8xl font-extrabold text-ghost-white mb-4">
        Jose Carlos Correa
      </h1>

      <h2 class="text-4xl font-bold text-ghost-white opacity-85">
        Web Engineer | Tech Enthusiast | Educator
      </h2>
    </div>
    <div
      class="bg-linear-to-t from-shadow-grey to-transparent h-12.5 absolute bottom-0 left-0 right-0"
    >
    </div>
  </div>

  <div class="w-full bg-shadow-grey">
    <div class="container mx-auto py-15 lg:px-20">
      <div
        class="grid gap-10 justify-items-center lg:grid-cols-[1fr_1fr] lg:grid-rows-1"
      >
        <div class="lg:row-span-2">
          <TiltedCard
            client:load
            imageSrc="https://avatars.githubusercontent.com/u/23535629?v=4"
            altText="Picture of Jose Carlos Correa (Jossdz)"
            captionText="Jose Carlos Correa (Jossdz)"
            containerHeight="300px"
            containerWidth="300px"
            imageHeight="300px"
            imageWidth="300px"
            rotateAmplitude={12}
            scaleOnHover={1.05}
            showMobileWarning={false}
            showTooltip
            displayOverlayContent
          />
        </div>

        <div class="">
          <SplitText
            client:idle
            text="Hey there 👋"
            className="text-2xl font-semibold text-center text-silver"
            delay={50}
            duration={1.25}
            ease="elastic.out(1, 0.3)"
            splitType="chars"
            from={{ opacity: 0, y: 40 }}
            to={{ opacity: 1, y: 0 }}
            threshold={0.1}
            rootMargin="-100px"
            textAlign="center"
          />
          <p class="text-base leading-relaxed text-ghost-white opacity-80 mt-6">
            I'm a Senior Frontend Engineer with 8 years of experience building
            web systems that reach millions of users — delivering robust,
            production-ready code with a strong focus on long-term quality and
            maintainability. I specialize in React, TypeScript, and Node.js, and
            I'm known for taking ownership of complex problems, raising team
            standards, and establishing the kind of shared best practices that
            make engineering cultures stronger.
          </p>
          <p class="text-base leading-relaxed text-ghost-white opacity-80 mt-6">
            I also mentor and teach. I've guided 230+ developers through
            fullstack engineering with JavaScript and TypeScript, and I design
            curriculum for industry professionals. Are you looking for someone
            who can own the frontend and elevate the team around them?
          </p>
        </div>
      </div>
    </div>
  </div>

  <div class="w-full bg-shadow-grey">
    <h2
      class="text-3xl lg:text-4xl font-extrabold tracking-tight text-frosted-blue uppercase mb-6 text-center mx-auto max-w-4xl"
    >
      Tech Stack
    </h2>

    <div class="-my-96 overflow-hidden max-h-[80vh]">
      <CurvedLoop
        className="max-h-96 relative"
        client:load
        marqueeText="Typescript ✦ React ✦ Remix ✦ NextJS ✦ SASS ✦ Tailwind CSS ✦ NodeJS ✦ Express ✦ GraphQL ✦ Docker ✦"
        speed={1}
        curveAmount={400}
      />
    </div>
  </div>
</Layout>
