---
import LineWaves from "@/components/LineWaves";
import { useTranslations } from "@/i18n/utils";
import type { Lang } from "@/i18n/ui";

type Props = { lang?: Lang };
const { lang = "en" } = Astro.props;
const t = useTranslations(lang);
---

<div class="w-full relative h-screen bg-shadow-grey">
  <LineWaves
    client:idle
    brightness={0.2}
    color1="#43627c"
    color2="#365571"
    color3="#2c4a63"
    colorCycleSpeed={1}
    edgeFadeWidth={0}
    enableMouseInteraction={false}
    innerLineCount={36}
    mouseInfluence={2}
    outerLineCount={19}
    rotation={-46}
    speed={0.2}
    warpIntensity={2.4}
  />
  <div
    class="w-full text-center absolute top-1/2 left-0 translate-y-[calc(-50%-50px)]"
  >
    <h1 class="text-4xl sm:text-6xl md:text-8xl font-extrabold text-ghost-white mb-4 animate-in fade-in slide-in-from-bottom-4 duration-700 fill-mode-both [animation-delay:100ms]">
      Jose Carlos Correa
    </h1>

    <h2 class="text-xl sm:text-2xl md:text-4xl font-bold text-ghost-white opacity-85 animate-in fade-in slide-in-from-bottom-4 duration-700 fill-mode-both [animation-delay:300ms]">
      {t("hero.subtitle")}
    </h2>
  </div>
  <div
    class="bg-linear-to-t from-shadow-grey to-transparent h-12.5 absolute bottom-0 left-0 right-0"
  >
  </div>
</div>
