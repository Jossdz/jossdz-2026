---
import SplitText from "@/components/SplitText";
import TiltedCard from "@/components/TiltedCard";
import { useTranslations } from "@/i18n/utils";
import type { Lang } from "@/i18n/ui";

type Props = { lang?: Lang };
const { lang = "en" } = Astro.props;
const t = useTranslations(lang);
---

<div class="w-full bg-shadow-grey">
  <div class="container mx-auto py-15 px-6 lg:px-20">
    <div
      class="grid gap-10 justify-items-center lg:grid-cols-[1fr_1fr] lg:grid-rows-1"
    >
      <div class="lg:row-span-2">
        <TiltedCard
          client:load
          imageSrc="https://avatars.githubusercontent.com/u/23535629?v=4"
          altText="Picture of Jose Carlos Correa (Jossdz)"
          captionText="Jose Carlos Correa (Jossdz)"
          containerHeight="300px"
          containerWidth="300px"
          imageHeight="300px"
          imageWidth="300px"
          rotateAmplitude={12}
          scaleOnHover={1.05}
          showMobileWarning={false}
          showTooltip
          displayOverlayContent
        />
      </div>

      <div class="">
        <SplitText
          client:idle
          text={t("about.greeting")}
          className="text-2xl font-semibold text-center text-silver"
          delay={50}
          duration={1.25}
          ease="elastic.out(1, 0.3)"
          splitType="chars"
          from={{ opacity: 0, y: 40 }}
          to={{ opacity: 1, y: 0 }}
          threshold={0.1}
          rootMargin="-100px"
          textAlign="center"
        />
        <p class="text-base leading-relaxed text-ghost-white opacity-80 mt-6">
          {t("about.bio1")}
        </p>
        <p class="text-base leading-relaxed text-ghost-white opacity-80 mt-6">
          {t("about.bio2")}
        </p>
        <div class="flex flex-col gap-3 mt-8 sm:flex-row sm:flex-wrap">
          <a
            href="mailto:carloscorrea.dev@gmail.com?subject=Let's%20Work%20Together"
            class="px-6 py-2.5 rounded-full border border-silver text-silver text-sm font-medium hover:bg-silver hover:text-shadow-grey transition-colors duration-200 text-center sm:w-auto w-full"
          >
            {t("about.cta.email")}
          </a>
          <a
            href="https://www.linkedin.com/in/jossdz"
            target="_blank"
            rel="noopener noreferrer"
            class="px-6 py-2.5 rounded-full text-sm font-medium transition-colors duration-200 text-center sm:w-auto w-full bg-[#0A66C2] text-white hover:bg-[#004182]"
          >
            {t("about.cta.linkedin")}
          </a>
        </div>
      </div>
    </div>
  </div>
</div>
